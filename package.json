{
  "name": "feralboard",
  "private": true,
  "scripts": {
    "install:pi-web": "npm --prefix apps/pi-web install",
    "install:website": "npm --prefix apps/website install",
    "install:node-apps": "npm run install:pi-web && npm run install:website",
    "firmware:build": "bash scripts/firmware/flash.sh --build-only",
    "firmware:flash": "sudo bash scripts/firmware/flash.sh --flash-only",
    "firmware:deploy": "sudo bash scripts/firmware/flash.sh",
    "dev:pi-web": "npm --prefix apps/pi-web run dev",
    "dev:website": "npm --prefix apps/website run dev",
    "build:pi-web": "npm --prefix apps/pi-web run build",
    "build:website": "npm --prefix apps/website run build",
    "smoke:pi-stack": "bash scripts/smoke/smoke-pi-stack.sh",
    "lint:website": "npm --prefix apps/website run lint",
    "test:website": "npm --prefix apps/website run test"
  }
}
